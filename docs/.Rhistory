annotate("text", x = 4.2, y = 0.45, label = "你, t=4", color = cols["you"], hjust = 0, size = 4.8) +
annotate("text", x = 4.2, y = d0 + 0.45, label = "邻居, t=4", color = cols["nei"], hjust = 0, size = 4.8) +
annotate("text", x = 7.2, y = d0 - beta * (7.2 - t_turn) + 0.5,
label = "邻居从 t=4 开始以 0.5c 朝你移动",
color = cols["nei"], hjust = 0, size = 4.8) +
# same-ish scale as before
coord_fixed(xlim = c(0, 10.5), ylim = c(-1, 8), expand = FALSE) +
scale_x_continuous(breaks = seq(0, 8, 2), name = "ct") +
scale_y_continuous(breaks = seq(-4, 8, 2), name = "x") +
labs(title = "同一坐标尺度下：四个事件点与各自的光锥") +
theme_minimal(base_size = 14) +
theme(
panel.grid = element_blank(),
plot.title = element_text(hjust = 0.5, face = "bold"),
panel.background = element_rect(fill = "transparent", colour = NA),
plot.background  = element_rect(fill = "transparent", colour = NA),
legend.position = "none"
)
p
ggsave(
"events_and_cones_same_scale.png",
plot = p,
width = 8.5,
height = 8,
dpi = 300,
bg = "transparent"
)
p
