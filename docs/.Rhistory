aes(x = ct[1], y = x[1], xend = ct[2], yend = x[2]),
color = cols["you"], linewidth = 1.3,
arrow = arrow(length = unit(0.18, "cm"), type = "closed")
) +
# neighbor worldline: before t=4
geom_segment(
data = neighbor_line_1,
aes(x = ct[1], y = x[1], xend = ct[2], yend = x[2]),
color = cols["neighbor"], linewidth = 1.3
) +
# neighbor worldline: after t=4, toward you at 0.5c
geom_segment(
data = neighbor_line_2,
aes(x = ct[1], y = x[1], xend = ct[2], yend = x[2]),
color = cols["neighbor"], linewidth = 1.3,
arrow = arrow(length = unit(0.18, "cm"), type = "closed")
) +
# event points as squares
geom_point(
data = subset(events, who == "you"),
aes(x = ct, y = x),
color = cols["you"], fill = cols["you"],
shape = 15, size = 3.8
) +
geom_point(
data = subset(events, who == "neighbor"),
aes(x = ct, y = x),
color = cols["neighbor"], fill = cols["neighbor"],
shape = 15, size = 3.8
) +
# labels
annotate("text", x = 0.3, y = 0.5, label = "你, t=0", color = cols["you"], hjust = 0, size = 5) +
annotate("text", x = 0.3, y = neighbor_start + 0.5, label = "邻居, t=0", color = cols["neighbor"], hjust = 0, size = 5) +
annotate("text", x = t_turn + 0.2, y = 0.5, label = "你, t=4", color = cols["you"], hjust = 0, size = 5) +
annotate("text", x = t_turn + 0.2, y = neighbor_start + 0.5, label = "邻居, t=4", color = cols["neighbor"], hjust = 0, size = 5) +
annotate("text", x = 8.2, y = neighbor_start - beta * (8.2 - t_turn) + 0.5,
label = "邻居以 0.5c 向你靠近", color = cols["neighbor"], hjust = 0, size = 5) +
coord_fixed(xlim = c(0, t_max + 1), ylim = c(-1, neighbor_start + cone_radius + 1), expand = FALSE) +
scale_x_continuous(breaks = seq(0, t_max, 2), name = "ct") +
scale_y_continuous(breaks = seq(0, neighbor_start + cone_radius, 2), name = "x") +
labs(title = "两个事件点与各自的光锥") +
theme_minimal(base_size = 14) +
theme(
panel.grid = element_blank(),
plot.title = element_text(hjust = 0.5, face = "bold"),
panel.background = element_rect(fill = "transparent", colour = NA),
plot.background  = element_rect(fill = "transparent", colour = NA),
legend.position = "none"
)
p
# save
ggsave(
filename = "events_and_cones_t0_t4.png",
plot = p,
width = 9,
height = 8,
dpi = 300,
bg = "transparent"
)
library(ggplot2)
library(grid)
#-----------------------------
# helpers
#-----------------------------
make_sector <- function(center_ct, center_x, angle, radius = 3.5, half_open = pi/4, n = 300) {
# angle: sector central direction in radians
th <- seq(angle - half_open, angle + half_open, length.out = n)
data.frame(
ct = c(center_ct, center_ct + radius * cos(th), center_ct),
x  = c(center_x,  center_x + radius * sin(th),  center_x)
)
}
make_ray <- function(ct0, x0, angle, radius = 3.5) {
data.frame(
ct = ct0,
x = x0,
ctend = ct0 + radius * cos(angle),
xend  = x0  + radius * sin(angle)
)
}
#-----------------------------
# parameters
#-----------------------------
d0 <- 8        # initial separation
t_turn <- 4    # neighbor starts moving at ct = 4
beta <- 0.5    # 0.5c toward you
Rcone <- 3.2   # cone radius for local event cones
cols <- c(
you = "#d62728",
nei = "#1f77b4"
)
#-----------------------------
# worldlines
#-----------------------------
# you: stay at x = 0
you_line <- data.frame(
ct = c(0, 10),
x  = c(0, 0)
)
# neighbor: stationary until t=4, then moves toward you at 0.5c
nei_line1 <- data.frame(
ct = c(0, t_turn),
x  = c(d0, d0)
)
nei_x_t4 <- d0
nei_line2 <- data.frame(
ct = c(t_turn, 10),
x  = c(nei_x_t4, nei_x_t4 - beta * (10 - t_turn))
)
#-----------------------------
# event points
#-----------------------------
events <- data.frame(
who = c("you", "nei", "you", "nei"),
ct  = c(0, 0, 4, 4),
x   = c(0, d0, 0, d0)
)
#-----------------------------
# local cones
#-----------------------------
# your worldline direction = horizontal => angle = 0
# neighbor at t=0 is stationary => angle = 0
# neighbor at t=4 moves toward you => slope = -beta, angle = atan(-beta)
ang_you <- 0
ang_nei_t0 <- 0
ang_nei_t4 <- atan(-beta)
cone_you_t0 <- make_sector(0, 0, angle = ang_you, radius = Rcone)
cone_nei_t0 <- make_sector(0, d0, angle = ang_nei_t0, radius = Rcone)
cone_you_t4 <- make_sector(4, 0, angle = ang_you, radius = Rcone)
cone_nei_t4 <- make_sector(4, d0, angle = ang_nei_t4, radius = Rcone)
# boundary rays for each cone
rays_you_t0 <- rbind(
make_ray(0, 0, ang_you - pi/4, Rcone),
make_ray(0, 0, ang_you + pi/4, Rcone)
)
rays_nei_t0 <- rbind(
make_ray(0, d0, ang_nei_t0 - pi/4, Rcone),
make_ray(0, d0, ang_nei_t0 + pi/4, Rcone)
)
rays_you_t4 <- rbind(
make_ray(4, 0, ang_you - pi/4, Rcone),
make_ray(4, 0, ang_you + pi/4, Rcone)
)
rays_nei_t4 <- rbind(
make_ray(4, d0, ang_nei_t4 - pi/4, Rcone),
make_ray(4, d0, ang_nei_t4 + pi/4, Rcone)
)
#-----------------------------
# plot
#-----------------------------
p <- ggplot() +
# shaded cones
geom_polygon(data = cone_you_t0, aes(ct, x), fill = cols["you"], alpha = 0.18, color = NA) +
geom_polygon(data = cone_you_t4, aes(ct, x), fill = cols["you"], alpha = 0.18, color = NA) +
geom_polygon(data = cone_nei_t0, aes(ct, x), fill = cols["nei"], alpha = 0.18, color = NA) +
geom_polygon(data = cone_nei_t4, aes(ct, x), fill = cols["nei"], alpha = 0.18, color = NA) +
# dashed cone boundaries
geom_segment(data = rays_you_t0, aes(x = ct, y = x, xend = ctend, yend = xend),
color = cols["you"], linetype = "dashed", linewidth = 0.9) +
geom_segment(data = rays_you_t4, aes(x = ct, y = x, xend = ctend, yend = xend),
color = cols["you"], linetype = "dashed", linewidth = 0.9) +
geom_segment(data = rays_nei_t0, aes(x = ct, y = x, xend = ctend, yend = xend),
color = cols["nei"], linetype = "dashed", linewidth = 0.9) +
geom_segment(data = rays_nei_t4, aes(x = ct, y = x, xend = ctend, yend = xend),
color = cols["nei"], linetype = "dashed", linewidth = 0.9) +
# worldlines
geom_segment(data = you_line, aes(x = ct[1], y = x[1], xend = ct[2], yend = x[2]),
color = cols["you"], linewidth = 1.3,
arrow = arrow(length = unit(0.16, "cm"), type = "closed")) +
geom_segment(data = nei_line1, aes(x = ct[1], y = x[1], xend = ct[2], yend = x[2]),
color = cols["nei"], linewidth = 1.3) +
geom_segment(data = nei_line2, aes(x = ct[1], y = x[1], xend = ct[2], yend = x[2]),
color = cols["nei"], linewidth = 1.3,
arrow = arrow(length = unit(0.16, "cm"), type = "closed")) +
# square event points
geom_point(data = subset(events, who == "you"),
aes(ct, x), shape = 15, size = 3.6, color = cols["you"]) +
geom_point(data = subset(events, who == "nei"),
aes(ct, x), shape = 15, size = 3.6, color = cols["nei"]) +
# separation marker at t=0
geom_segment(aes(x = 0, y = 0, xend = 0, yend = d0),
color = "grey50", linewidth = 0.7) +
annotate("text", x = 0.22, y = d0 / 2, label = "8", color = "grey50", size = 4) +
# labels
annotate("text", x = 0.3, y = 0.45, label = "你, t=0", color = cols["you"], hjust = 0, size = 4.8) +
annotate("text", x = 0.3, y = d0 + 0.45, label = "邻居, t=0", color = cols["nei"], hjust = 0, size = 4.8) +
annotate("text", x = 4.2, y = 0.45, label = "你, t=4", color = cols["you"], hjust = 0, size = 4.8) +
annotate("text", x = 4.2, y = d0 + 0.45, label = "邻居, t=4", color = cols["nei"], hjust = 0, size = 4.8) +
annotate("text", x = 7.2, y = d0 - beta * (7.2 - t_turn) + 0.5,
label = "邻居从 t=4 开始以 0.5c 朝你移动",
color = cols["nei"], hjust = 0, size = 4.8) +
# same-ish scale as before
coord_fixed(xlim = c(0, 10.5), ylim = c(-1, 12), expand = FALSE) +
scale_x_continuous(breaks = seq(0, 10, 2), name = "ct") +
scale_y_continuous(breaks = seq(0, 12, 2), name = "x") +
labs(title = "同一坐标尺度下：四个事件点与各自的光锥") +
theme_minimal(base_size = 14) +
theme(
panel.grid = element_blank(),
plot.title = element_text(hjust = 0.5, face = "bold"),
panel.background = element_rect(fill = "transparent", colour = NA),
plot.background  = element_rect(fill = "transparent", colour = NA),
legend.position = "none"
)
p
ggsave(
"events_and_cones_same_scale.png",
plot = p,
width = 8.5,
height = 8,
dpi = 300,
bg = "transparent"
)
