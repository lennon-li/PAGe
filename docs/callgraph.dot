digraph PAGe_pipeline {
  graph [rankdir=LR, fontname="Helvetica", fontsize=11, nodesep=0.4, ranksep=1.2];
  node  [fontname="Helvetica", fontsize=10, style=filled, shape=box, margin="0.15,0.06"];
  edge  [fontname="Helvetica", fontsize=9, arrowsize=0.7];

  subgraph cluster_M0__Ignition {
    label="M0: Ignition";
    style=filled; color="#856404"; fillcolor="#fff3cd";
    fontcolor="#856404"; fontsize=12; fontname="Helvetica-Bold";
    fitIgnition [label="fitIgnition", shape=box];
    scoreIgnition [label="scoreIgnition", shape=ellipse];
    flag_ignition_rules [label="flag_ignition_rules", shape=ellipse];
    run_ignition_detection [label="run_ignition_detection", shape=ellipse];
    run_m0_detection [label="run_m0_detection", shape=box];
    m0_retro_run [label="m0_retro_run", shape=ellipse];
    m0_retro_score [label="m0_retro_score", shape=ellipse];
    apply_ignition_threshold [label="apply_ignition_threshold", shape=ellipse];
  }

  subgraph cluster_M1__Reference {
    label="M1: Reference";
    style=filled; color="#155724"; fillcolor="#d4edda";
    fontcolor="#155724"; fontsize=12; fontname="Helvetica-Bold";
    build_reference_curve [label="build_reference_curve", shape=ellipse];
    fit_reference_gam [label="fit_reference_gam", shape=box];
    get_ref_curve [label="get_ref_curve", shape=ellipse];
    get_ref_params [label="get_ref_params", shape=ellipse];
    get_ref_fit [label="get_ref_fit", shape=ellipse];
    get_ref_n_weeks [label="get_ref_n_weeks", shape=ellipse];
    load_reference [label="load_reference", shape=ellipse];
    reference_from_hist [label="reference_from_hist", shape=ellipse];
  }

  subgraph cluster_M1__Alignment {
    label="M1: Alignment";
    style=filled; color="#155724"; fillcolor="#c3e6cb";
    fontcolor="#155724"; fontsize=12; fontname="Helvetica-Bold";
    align_season [label="align_season", shape=ellipse];
    align_season_multi [label="align_season_multi", shape=ellipse];
    run_alignment_prospective [label="run_alignment_prospective", shape=box];
    run_alignment_loso [label="run_alignment_loso", shape=ellipse];
    m1_fit_season [label="m1_fit_season", shape=ellipse];
    m1_align_one [label="m1_align_one", shape=ellipse];
    m1_walkforward_predictions [label="m1_walkforward_predictions", shape=box];
    m1_walkforward_multi [label="m1_walkforward_multi", shape=box];
    inject_m1_into_snapshots [label="inject_m1_into_snapshots", shape=box];
    multi_template_align [label="multi_template_align", shape=ellipse];
    ensemble_align [label="ensemble_align", shape=ellipse];
    weibull_template_weights [label="weibull_template_weights", shape=ellipse];
    compute_peak_status [label="compute_peak_status", shape=ellipse];
    get_peak_status [label="get_peak_status", shape=ellipse];
    m1_peak_week_dist [label="m1_peak_week_dist", shape=ellipse];
    summarise_peak_dist [label="summarise_peak_dist", shape=ellipse];
  }

  subgraph cluster_M1__LOSO_Tuning {
    label="M1: LOSO Tuning";
    style=filled; color="#0c4a30"; fillcolor="#b8dacc";
    fontcolor="#0c4a30"; fontsize=12; fontname="Helvetica-Bold";
    loso_m1_cv [label="loso_m1_cv", shape=ellipse];
    nested_loso_m1 [label="nested_loso_m1", shape=ellipse];
    run_m1_loso_fold [label="run_m1_loso_fold", shape=ellipse];
    score_m1_loso [label="score_m1_loso", shape=ellipse];
    m1_loso_grid_search [label="m1_loso_grid_search", shape=ellipse];
  }

  subgraph cluster_M2__Spec___Features {
    label="M2: Spec & Features";
    style=filled; color="#004085"; fillcolor="#cce5ff";
    fontcolor="#004085"; fontsize=12; fontname="Helvetica-Bold";
    stage2_make_spec [label="stage2_make_spec", shape=box];
    expand_grid_specs [label="expand_grid_specs", shape=box];
    stage2_build_joint_formula [label="stage2_build_joint_formula", shape=box];
    stage2_exclude_newseason [label="stage2_exclude_newseason", shape=box];
    prep_stage2_joint [label="prep_stage2_joint", shape=box];
    add_prospective_derivs_link [label="add_prospective_derivs_link", shape=box];
    stage2_ramp_weight [label="stage2_ramp_weight", shape=box];
    logit_stable [label="logit_stable", shape=box];
    make_soft_cap_fn [label="make_soft_cap_fn", shape=box];
    format_current_for_stage2 [label="format_current_for_stage2", shape=box];
  }

  subgraph cluster_M2__Training {
    label="M2: Training";
    style=filled; color="#003060"; fillcolor="#b8d4f0";
    fontcolor="#003060"; fontsize=12; fontname="Helvetica-Bold";
    train_stage2_joint [label="train_stage2_joint", shape=box];
    train_stage2_joint_prepped [label="train_stage2_joint_prepped", shape=box];
    refit_stage2_weekly [label="refit_stage2_weekly", shape=box];
    stage2_spec_from_tuning [label="stage2_spec_from_tuning", shape=box];
    score_stage2_metrics [label="score_stage2_metrics", shape=box];
    nested_loso_m2_eval_fold [label="nested_loso_m2_eval_fold", shape=ellipse];
    nested_loso_m2_eval_weekly_refit [label="nested_loso_m2_eval_weekly_refit", shape=box];
    nested_loso_refit_best [label="nested_loso_refit_best", shape=box];
    loso_m1_m2_joint [label="loso_m1_m2_joint", shape=box];
  }

  subgraph cluster_M2__Grid_Tuning {
    label="M2: Grid Tuning";
    style=filled; color="#002050"; fillcolor="#9ec5e8";
    fontcolor="#002050"; fontsize=12; fontname="Helvetica-Bold";
    nested_loso_grid_search [label="nested_loso_grid_search", shape=box];
    nested_loso_parallel [label="nested_loso_parallel", shape=ellipse];
    m2_nested_loso_score [label="m2_nested_loso_score", shape=ellipse];
    select_best_spec [label="select_best_spec", shape=ellipse];
    plot_stage2_joint_fit_by_season [label="plot_stage2_joint_fit_by_season", shape=box];
  }

  subgraph cluster_M2__Predict {
    label="M2: Predict";
    style=filled; color="#4a0080"; fillcolor="#e2ccff";
    fontcolor="#4a0080"; fontsize=12; fontname="Helvetica-Bold";
    m2_predict_one [label="m2_predict_one", shape=box];
  }

  subgraph cluster_Deployment {
    label="Deployment";
    style=filled; color="#721c24"; fillcolor="#f8d7da";
    fontcolor="#721c24"; fontsize=12; fontname="Helvetica-Bold";
    run_prospective_pipeline [label="run_prospective_pipeline", shape=box];
    run_m2_forecast [label="run_m2_forecast", shape=box];
    run_m1_forecast [label="run_m1_forecast", shape=ellipse];
    run_m0_forecast [label="run_m0_forecast", shape=ellipse];
    run_weekly_pipeline [label="run_weekly_pipeline", shape=ellipse];
  }

  subgraph cluster_Utilities {
    label="Utilities";
    style=filled; color="#383d41"; fillcolor="#e2e3e5";
    fontcolor="#383d41"; fontsize=12; fontname="Helvetica-Bold";
    safe_logit [label="safe_logit", shape=ellipse];
    clamp [label="clamp", shape=ellipse];
    nll_binom [label="nll_binom", shape=ellipse];
    brier_score [label="brier_score", shape=ellipse];
    weibull_weights [label="weibull_weights", shape=ellipse];
    mmwr_to_date [label="mmwr_to_date", shape=ellipse];
    season_of_date [label="season_of_date", shape=ellipse];
  }

  // Call edges
  expand_grid_specs -> clamp;
  expand_grid_specs -> stage2_make_spec;
  format_current_for_stage2 -> add_prospective_derivs_link;
  format_current_for_stage2 -> stage2_spec_from_tuning;
  format_current_for_stage2 -> train_stage2_joint;
  inject_m1_into_snapshots -> logit_stable;
  inject_m1_into_snapshots -> run_alignment_prospective;
  logit_stable -> fitIgnition;
  loso_m1_m2_joint -> add_prospective_derivs_link;
  loso_m1_m2_joint -> m1_walkforward_multi;
  loso_m1_m2_joint -> m1_walkforward_predictions;
  loso_m1_m2_joint -> prep_stage2_joint;
  loso_m1_m2_joint -> score_stage2_metrics;
  loso_m1_m2_joint -> train_stage2_joint;
  m1_walkforward_multi -> m1_walkforward_predictions;
  m1_walkforward_multi -> run_alignment_prospective;
  nested_loso_grid_search -> add_prospective_derivs_link;
  nested_loso_grid_search -> m1_walkforward_multi;
  nested_loso_grid_search -> refit_stage2_weekly;
  nested_loso_grid_search -> stage2_make_spec;
  nested_loso_grid_search -> train_stage2_joint;
  nested_loso_m2_eval_weekly_refit -> add_prospective_derivs_link;
  nested_loso_m2_eval_weekly_refit -> m2_predict_one;
  nested_loso_m2_eval_weekly_refit -> make_soft_cap_fn;
  nested_loso_m2_eval_weekly_refit -> refit_stage2_weekly;
  nested_loso_m2_eval_weekly_refit -> stage2_exclude_newseason;
  nested_loso_m2_eval_weekly_refit -> train_stage2_joint;
  nested_loso_refit_best -> nested_loso_grid_search;
  nested_loso_refit_best -> plot_stage2_joint_fit_by_season;
  nested_loso_refit_best -> train_stage2_joint;
  plot_stage2_joint_fit_by_season -> stage2_make_spec;
  prep_stage2_joint -> logit_stable;
  prep_stage2_joint -> m1_walkforward_predictions;
  prep_stage2_joint -> stage2_ramp_weight;
  refit_stage2_weekly -> format_current_for_stage2;
  refit_stage2_weekly -> prep_stage2_joint;
  refit_stage2_weekly -> score_stage2_metrics;
  refit_stage2_weekly -> train_stage2_joint;
  run_m0_detection -> run_m2_forecast;
  run_m2_forecast -> add_prospective_derivs_link;
  run_m2_forecast -> m2_predict_one;
  run_m2_forecast -> make_soft_cap_fn;
  run_m2_forecast -> refit_stage2_weekly;
  run_m2_forecast -> run_m0_detection;
  run_m2_forecast -> stage2_exclude_newseason;
  run_prospective_pipeline -> run_m0_detection;
  run_prospective_pipeline -> run_m2_forecast;
  stage2_build_joint_formula -> stage2_make_spec;
  stage2_make_spec -> expand_grid_specs;
  stage2_make_spec -> stage2_build_joint_formula;
  stage2_make_spec -> stage2_exclude_newseason;
  stage2_spec_from_tuning -> stage2_make_spec;
  train_stage2_joint -> add_prospective_derivs_link;
  train_stage2_joint -> prep_stage2_joint;
  train_stage2_joint -> stage2_make_spec;
  train_stage2_joint -> train_stage2_joint_prepped;
  train_stage2_joint_prepped -> stage2_build_joint_formula;
  train_stage2_joint_prepped -> stage2_make_spec;
}