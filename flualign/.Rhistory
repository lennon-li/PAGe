## extract current season data
currentSeason <- getCurrentD()
## to change to surveillance week number as last observed week
##currentSeason <- getCurrentD(lastWeek= 44)
#check identifiablity for scale and shift
##manual override for testing
#hyper$WEEK_THRESHOLD_DELTA = 20
#hyper$LAMBDA_DELTA = hyper$LAMBDA_DELTA * 0.5
scale_diag <- check_scale_identifiability(currentD  = currentSeason,g_ref_fun = g_ref_fun, hyper= hyper)
print(scale_diag$allow_scale_rec)
#peak analysis
# Historical data
rule <- peak_week_distribution(
theD,
value_col  = NULL,   # uses p or builds p = y/(y+neg)
k_for_drop = 2L,     # look 2 weeks after the peak
drop_prob  = 0.5     # median drop across seasons
)
out <- flagPeak(
df               = currentSeason,
value_col        = NULL,   # use y/(y+neg)
min_week         = rule$min_week,
max_week         = rule$max_week,
drop_frac        = rule$drop_frac,
min_abs_drop     = rule$min_abs_drop,
min_consec_below = rule$min_consec_below
)
if (is.na(out$flag_week)) {
# ---- NO PEAK DETECTED YET: normal alignment on all observed weeks ----
res <- align_forecast_pipeline_dilate(
currentD      = currentSeason,
g_ref_fun     = g_ref_fun,
g_ref_mu_se   = g_ref_mu_se,
hyper         = hyper,
allow_scale   = scale_diag$allow_scale_rec,
level         = 0.95
)
} else {
# ---- PEAK DETECTED: freeze alignment up to peak and follow template ----
# Here align_after_peak_template internally:
#  * converts out$flag_week (epi week) → newWeek
#  * truncates currentSeason to newWeek <= peak_newWeek
#  * runs alignment only on that truncated data
#  * predicts the rest of the season from that anchored curve
res <-forecast_post_peak_gam(
currentSeason = currentSeason,                 # includes flag_week etc.
g_ref_fun     = g_ref_fun,
level         = 0.95
)
}
## 4. Plot as before, but pass peakInfo so plotRes can grey-out forecasts ---
p <- plotRes(res, peakInfo = out, currentSeason = currentSeason)
res$pred_df = res$pred_df %>% left_join(currentSeason %>% select(newWeek,p))
p = as.list(c(hist = "hist", ref = "ref", data = "data") )
p1 = ggplot() +
geom_ribbon(
data = subset(res$pred_df, kind == "forecast"),
aes(x = newWeek, ymin = p_lo, ymax = p_hi),
fill = "steelblue", alpha = 0.20
) +
geom_line(
data = subset(res$pred_df, kind == "forecast"),
aes(x = newWeek, y = p_hat),
color = "steelblue", linewidth = 1.2
) +
geom_line(
data = theD %>% filter(weekF >8),
aes(x = newWeek, y = fit, group = season),
color = "grey70", linewidth = 0.6, alpha = 0.4
) +
geom_line(
data = subset(res$pred_df, kind == "observed"),
aes(x = newWeek, y = p_hat),
color = "tomato", size = 2
) +
geom_point(
data = res$pred_df,
aes(x = newWeek, y = p)
)
p1 = ggplot() +
geom_ribbon(
data = subset(res$pred_df, kind == "forecast"),
aes(x = newWeek, ymin = p_lo, ymax = p_hi),
fill = "steelblue", alpha = 0.20
) +
geom_line(
data = subset(res$pred_df, kind == "forecast"),
aes(x = newWeek, y = p_hat),
color = "steelblue", linewidth = 1.2
) +
geom_line(
data = theD %>% filter(weekF >8),
aes(x = newWeek, y = fit, group = season),
color = "grey70", linewidth = 0.6, alpha = 0.4
) +
geom_line(
data = subset(res$pred_df, kind == "observed"),
aes(x = newWeek, y = p_hat),
color = "tomato", size = 2
) +
geom_point(
data = res$pred_df,
aes(x = newWeek, y = p)
)+
geom_vline(xintercept = res$last_obs, linetype = 2, color = "grey50") +
{ if (!any(is.na(res$peak$t_peak))) geom_vline(xintercept = res$peak$t_peak, color = "purple", linetype = 2) } +
labs(
title = sprintf("shift= %.2f weeks, dilation= %.3f",
res$tau, res$delta),
subtitle = if (!any(is.na(res$peak$t_peak))) {
sprintf("Peak ~ week %.1f ",
res$peak$t_peak)
} else "Peak CI unavailable yet (early/unstable δ).",
x = "Week of year", y = "Percentage positivity)"
) +
theme_minimal(base_size = 13)
p1
