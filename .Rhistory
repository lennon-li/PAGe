)
)
# --- build specs ---
specs <- purrr::pmap(
list(grid$delta, grid$K, grid$T, grid$k_f),
function(delta, K, T, k_f) {
# for non-smooth template, k_f is irrelevant; pass a safe default
if (is.na(k_f)) k_f <- k_f_grid[1]
stage2_make_spec(
delta = delta,
