expand_grid_specs <- function(
# ---- core tuning grids ----
delta_grid = -3:3,
K_grid     = 1:6,
T_grid     = c("O","S"),           # "O" offset, "S" smooth, "N" none (optional)
k_f_grid   = c(6L, 8L, 10L),       # used only when T == "S"
# ---- fixed by default (your request) ----
alpha_state = 0.20,
k_2 = 0L,
# ---- vary "all dfs" (basis sizes) in a *small* default way ----
# 0 disables term; second value is the default "on" setting
k_w_grid = c(0L, 8L),
k_s_grid = c(0L, 4L),
k_e_grid = c(0L, 6L),
k_n_grid = c(0L, 6L),
k_1_grid = c(0L, 6L),
# ---- other knobs (kept small by default) ----
pre_buffer_grid = c(1L),           # change to c(0L,1L) if you want to tune it too
leads = c(1L, 2L),
bs_week        = "ts",
bs_fs_marginal = "ts",
# ---- output ----
build_specs = TRUE,
verbose = TRUE
) {
if (!exists("stage2_make_spec", mode = "function")) {
stop("expand_grid_specs(): stage2_make_spec() not found. Source your prospective_training file first.")
}
if (!requireNamespace("dplyr", quietly = TRUE)) stop("Please install dplyr.")
if (!requireNamespace("tidyr", quietly = TRUE)) stop("Please install tidyr.")
if (!requireNamespace("purrr", quietly = TRUE)) stop("Please install purrr.")
# coerce
delta_grid <- as.integer(delta_grid)
K_grid     <- as.integer(K_grid)
T_grid     <- as.character(T_grid)
k_f_grid   <- as.integer(k_f_grid)
k_w_grid <- as.integer(k_w_grid)
k_s_grid <- as.integer(k_s_grid)
k_e_grid <- as.integer(k_e_grid)
k_n_grid <- as.integer(k_n_grid)
k_1_grid <- as.integer(k_1_grid)
pre_buffer_grid <- as.integer(pre_buffer_grid)
leads <- as.integer(leads)
alpha_state <- as.numeric(alpha_state)
if (!is.finite(alpha_state) || alpha_state <= 0 || alpha_state >= 1) {
stop("alpha_state must be in (0,1).")
}
# --- build base grid for df/basis sizes & other knobs ---
base_grid <- tidyr::crossing(
k_w = k_w_grid,
k_s = k_s_grid,
k_e = k_e_grid,
k_n = k_n_grid,
k_1 = k_1_grid,
pre_buffer = pre_buffer_grid
)
# --- template grid: k_f only for T="S" ---
grid_S <- tidyr::crossing(delta = delta_grid, K = K_grid, T = "S", k_f = k_f_grid)
grid_notS <- tidyr::crossing(delta = delta_grid, K = K_grid, T = setdiff(T_grid, "S")) |>
dplyr::mutate(k_f = NA_integer_)
template_grid <- dplyr::bind_rows(grid_notS, grid_S) |>
dplyr::filter(.data$T %in% T_grid)
# full grid
grid <- tidyr::crossing(template_grid, base_grid) |>
dplyr::mutate(
alpha_state = alpha_state,
k_2 = as.integer(k_2),
bs_week = bs_week,
bs_fs_marginal = bs_fs_marginal,
leads = list(leads),
spec_id = dplyr::if_else(
.data$T == "S",
sprintf("T%s_d%+d_K%d_kf%d_kw%d_ks%d_ke%d_kn%d_k1%d_pb%d",
.data$T, .data$delta, .data$K, .data$k_f,
.data$k_w, .data$k_s, .data$k_e, .data$k_n, .data$k_1, .data$pre_buffer),
sprintf("T%s_d%+d_K%d_kw%d_ks%d_ke%d_kn%d_k1%d_pb%d",
.data$T, .data$delta, .data$K,
.data$k_w, .data$k_s, .data$k_e, .data$k_n, .data$k_1, .data$pre_buffer)
)
) |>
dplyr::arrange(.data$T, .data$delta, .data$K, dplyr::coalesce(.data$k_f, 0L),
.data$k_w, .data$k_s, .data$k_e, .data$k_n, .data$k_1, .data$pre_buffer)
if (isTRUE(build_specs)) {
grid <- grid |>
dplyr::mutate(
spec = purrr::pmap(
list(delta, K, k_f, alpha_state, pre_buffer, leads, T,
k_w, k_s, k_e, k_n, k_1, k_2, bs_week, bs_fs_marginal),
function(delta, K, k_f, alpha_state, pre_buffer, leads, T,
k_w, k_s, k_e, k_n, k_1, k_2, bs_week, bs_fs_marginal) {
# if T != "S", k_f is irrelevant; pass a safe default
if (is.na(k_f)) k_f <- k_f_grid[1]
stage2_make_spec(
delta = as.integer(delta),
K = as.integer(K),
k_f = as.integer(k_f),
alpha_state = as.numeric(alpha_state),
pre_buffer = as.integer(pre_buffer),
leads = as.integer(unlist(leads)),
T = as.character(T),
k_w = as.integer(k_w),
k_s = as.integer(k_s),
k_e = as.integer(k_e),
k_n = as.integer(k_n),
k_1 = as.integer(k_1),
k_2 = as.integer(k_2),
bs_week = bs_week,
bs_fs_marginal = bs_fs_marginal
)
}
)
)
}
if (isTRUE(verbose)) {
message("[expand_grid_specs] grid rows = ", nrow(grid),
" | core: delta=", length(delta_grid),
" K=", length(K_grid),
" T={", paste(T_grid, collapse=","), "}",
" k_f=", length(k_f_grid), " (only when T='S')",
" | dfs: k_w=", paste(k_w_grid, collapse=","),
" k_s=", paste(k_s_grid, collapse=","),
" k_e=", paste(k_e_grid, collapse=","),
" k_n=", paste(k_n_grid, collapse=","),
" k_1=", paste(k_1_grid, collapse=","),
" k_2 fixed=", k_2,
" | alpha_state fixed=", alpha_state,
" | pre_buffer=", paste(pre_buffer_grid, collapse=","))
}
grid
}
